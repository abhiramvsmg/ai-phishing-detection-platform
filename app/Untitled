@tailwind base;
@tailwind components;
@tailwind utilities;

@keyframes scan {
  from { top: 0%; opacity: 0; }
  50% { opacity: 1; }
  to { top: 100%; opacity: 0; }
}

.animate-scan {
  animation: scan 4s linear infinite;
}

/* Smooth Scrolling for the #pricing link */
html {
  scroll-behavior: smooth;
}

/* Ensure sections have spacing when jumping to ID */
[id] {
  scroll-margin-top: 100px;
}